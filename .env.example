# Copy to .env (gitignored). Never commit real values.
PROJECT_ROOT=/abs/path/to/mariupol-property-seizures
# Russia-routed proxy for the geoblocked court portals:
COURT_PROXY=socks5h://user:pass@host:1080
DATABASE_URL=postgresql://user:pass@localhost:5432/mariupol_seizures
CRAWL_DATE_FROM=01.03.2024
CRAWL_DATE_TO=01.07.2026
# Paste a real ГАС Правосудие results URL from DevTools, with placeholders:
# RESULTS_TEMPLATE={court}/modules.php?name=sud_delo&...&page={page}
# Contact (email or project URL) for OSM Nominatim's User-Agent policy:
GEOCODE_CONTACT=you@example.com
# Google Geocoding API key (Tier A3 geocoding fallback, scripts/24):
GOOGLE_MAPS_API_KEY=
# Telegram (MTProto) demand-side resale scan (scripts/50). api_id/api_hash from
# my.telegram.org; the session file (data/telegram_session, gitignored) holds an
# auth token = secret. First run is interactive (login code + any 2FA).
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE_NUMBER=
# TELEGRAM_SESSION=data/telegram_session   # optional override
# TELEGRAM_HISTORY_LIMIT=8000              # first-run per-channel history cap
# TELEGRAM_FETCH_MEDIA=false               # download listing photos (heavy; off by default)
# Web real-estate scan caps (scripts/49):
# REALESTATE_MAX_PAGES=20
# REALESTATE_MAX_DETAIL=400
